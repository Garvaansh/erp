# Env Example
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:[password]@[url]:[port]/[DB_NAME]?sslmode=disable
GOOSE_MIGRATION_DIR=db/migrations

DATABASE_URL=postgres://postgres:[password]@[url]:[port]/[DB_NAME]
ADMIN_EMAIL=email
ADMIN_PASSWORD=password
JWT_SECRET=local_dev_secret_do_not_use_in_prod
PORT=8080

# CORS setup, example: "http://localhost:3000"
FRONTEND_URL=""